# ── Supabase (optional) ────────────────────────────────────────────────────
# Leave BLANK to run local-first (notes/visits saved per-device, no account).
# Fill both to switch on the shared backend (cross-device notes, visit counts,
# photo uploads). Find them in Supabase → Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Login gate (optional) ──────────────────────────────────────────────────
# Set a shared secret word she must enter to unlock (e.g. your anniversary).
# Leave blank for a name-only gate.
VITE_GATE_CODE=
